<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.5.xsd"
                   logicalFilePath="liquibase/changelogs" objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="createTableBooks" author="workshops">
        <createTable tableName="book">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="title" type="varchar" />
            <column name="author" type="varchar" />
            <column name="isbn" type="varchar" />
            <column name="description" type="varchar" />
        </createTable>
        <rollback>
            <dropTable tableName="book" />
        </rollback>
    </changeSet>

    <changeSet id="createTableUsers" author="workshops">
        <createTable tableName="user">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="username" type="varchar">
                <constraints unique="true" />
            </column>
            <column name="password" type="varchar" />
            <column name="firstname" type="varchar" />
            <column name="lastname" type="varchar" />
            <column name="role" type="varchar" />
            <column name="lastlogin" type="datetime" />
        </createTable>
        <rollback>
            <dropTable tableName="user" />
        </rollback>
    </changeSet>

    <changeSet author="workshops" id="createDefaultAdmin">
        <sql>
            INSERT INTO "user" (username, password, firstname, lastname, role)
            VALUES ('dbUser', 'password', 'Default', 'Default', 'ADMIN');
        </sql>
        <rollback>
            <sql>
                DELETE FROM "user";
            </sql>
        </rollback>
    </changeSet>

    <!--
        This is for demonstration purposes only.
        Checking credentials of any kind into source control should be avoided.
    -->
    <changeSet author="workshops" id="updateDefaultAdmin">
        <sql>
            UPDATE "user" SET password = '$2a$10$vAiSOk2MzsgZ8EvDNSEkWuZ47.bSwEHTgnl4mN.Zgz4TrxZQ4S6Ee'
            WHERE username = 'dbUser';
        </sql>
        <rollback>
            <sql>
                UPDATE "user" SET password = 'password'
                WHERE username = 'dbUser';
            </sql>
        </rollback>
    </changeSet>

    <changeSet author="workshops" id="addDefaultBooks">
        <sql>
            INSERT INTO book (isbn, title, author, description)
            VALUES ('978-0201633610', 'Design Patterns', 'Erich Gamma',
            'Mit Design Patterns lassen sich wiederkehrende Aufgaben in der objektorientierten Softwareentwicklung effektiv lösen.');

            INSERT INTO book (isbn, title, author, description)
            VALUES ('978-3826655487', 'Clean Code', 'Robert C. Martin',
            'Das einzige praxisnahe Buch, mit dem Sie lernen, guten Code zu schreiben!');

            INSERT INTO book (isbn, title, author, description)
            VALUES ('978-3836211161', 'Coding for Fun', 'Gottfried Wolmeringer',
            'Dieses unterhaltsam geschriebene Buch führt Sie spielerisch durch die spektakuläre Geschichte unserer Blechkollegen.');
        </sql>
        <rollback>
            <sql>
                DELETE FROM book;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="createTableAuthors" author="workshops">
        <createTable tableName="author">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="name" type="varchar" />
        </createTable>
        <createTable tableName="author_books">
            <column name="authors_id" type="bigint">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="books_id" type="bigint">
                <constraints nullable="false" primaryKey="true"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="author" />
            <dropTable tableName="author_books" />
        </rollback>
    </changeSet>

    <changeSet author="workshops" id="addDefaultAuthors">
        <sql>
            INSERT INTO author (name)
            VALUES ('Erich Gamma');

            INSERT INTO author (name)
            VALUES ('Robert C. Martin');

            INSERT INTO author (name)
            VALUES ('Gottfried Wolmeringer');

            INSERT INTO author_books (authors_id, books_id)
            VALUES (1, 1);

            INSERT INTO author_books (authors_id, books_id)
            VALUES (2, 2);

            INSERT INTO author_books (authors_id, books_id)
            VALUES (3, 3);
        </sql>
        <rollback>
            <sql>
                DELETE FROM author;
                DELETE FROM author_books;
            </sql>
        </rollback>
    </changeSet>
</databaseChangeLog>
